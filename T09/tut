#include <stdio.h>
#include <stdlib.h>

struct misura{
	int aaaa,mm,gg,hh,min,ss,ms,umid;
	char id[20];
	float temp, vel;
};
struct misura * lettura(FILE *f,int *n_letti){
	struct misura* letti;
	struct misura buf;
	char s[200];
	int a,b;
	fgets(s,sizeof(s),f);
	a=atoi(s);
	fgets(s,sizeof(s),f);
	b=atoi(s);
	if(b<a||a<0||b<0){
		printf("[ERRORE]\nI limiti non sono validi\n");
		exit(3);
	}
	int size=(b-a+1);
	letti=malloc(sizeof(struct misura)*size);
	if(letti==NULL){
		printf("[ERRORE]\n Allocazione dinamica non andata a buon fine\n");
			exit(4);
		}

	int i;
	for(i=0;i<a;i++){
		fgets(s,sizeof(s),f);
	}
	int n_conv;
	
	while(fgets(s,sizeof(s),f)){

		n_conv=sscanf(s,"%d-%d-%d %d:%d:%d.%d %s %f %d%% %f",&buf.aaaa,&buf.mm,&buf.gg,&buf.hh,&buf.min,&buf.ss,&buf.ms,
						buf.id,&buf.temp,&buf.umid,&buf.vel);
		if(n_conv==11){
			letti[*n_letti]=buf;
			*n_letti=(*n_letti)+1;
		}
		if((*n_letti)>=size) break;
	}
	struct misura *temp;
	temp=realloc(letti,sizeof(struct misura)*(*n_letti));
	if(temp==NULL){
		printf("[ERRORE]\nReallocazione non andata a buon fine\n");
		exit(5);
	}
	letti=temp;
	return letti;
}
int main(int argc, char * argv[]){
	if(argc!=2){
		printf("[ERRORE]\nInserisci un file.txt da leggere\n");
		exit(1);
	}
	FILE *f;
	int n_letti=0;
	f=fopen(argv[1],"r");
	if(f==NULL){
		printf("[ERRORE]\nIl file non si e' aperto correttamente\n");
		exit(2);
	}
	struct misura *letti;
	letti=lettura(f,&n_letti);
	int i;
	
	for(i=0;i<(n_letti);i++){
		printf("%04d-%02d-%02d %02d:%02d:%02d.%03d %s %.2f %d%% %.2f\n",letti[i].aaaa,letti[i].mm,letti[i].gg,letti[i].hh,letti[i].min
												   ,letti[i].ss,letti[i].ms,letti[i].id,letti[i].temp,letti[i].umid,letti[i].vel);
	}
	// 1) IDENTIFICATIVI
	printf("[IDENTIFICATIVI]\n");
	for(i=n_letti-1;i>=0;i--){
		printf("%s\n",letti[i].id);
	}
	// 2) MASSIMA TEMPERATURA
	float max=letti[0].temp;
	for(i=1;i<(n_letti);i++){
		if(letti[i].temp>max){
			max=letti[i].temp;
		}
	}
	// 3) NUMERO RIGHE
	printf("[RIGHE]\n%d\n",n_letti);
	printf("[MAX-TEMP]\n%.2f\n",max);
	return 0;
}
